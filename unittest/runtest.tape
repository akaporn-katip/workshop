# Where should we write the GIF?
Output runtest.gif

# Set up a 1200x600 terminal with 46px font.
Set FontSize 32
Set Width 1200
Set Height 600

# Type a command in the terminal.
Type "npm run test"

# Pause for dramatic effect...
Sleep 500ms

# Run the command by pressing enter.
Enter

# Admire the output for a bit.
Sleep 5s
